<% if(typeof action !== 'undefined' && action == 'save' ) { %> 
<div class="modal" id="feedbackModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><%= success ? "Success" : "Error" %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
        <div class="modal-body">
            <p><%= message %></p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="redirectToPage('/users/add')" data-bs-dismiss="modal">Close</button>
            <button type="button" class="btn btn-primary" onclick="redirectToPage('/users')">Ok</button>
        </div>
    </div>
  </div>
</div>
<% } %>
