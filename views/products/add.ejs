<div class="col-sm-10">
  <div class="col-sm-5">
    <br>
    
    <% if (typeof success !== "undefined" && typeof pageAction!== "undefined" && pageAction !== "add") { %>
      <div class="alert <%= success === true ? 'alert-success' : 'alert-warning' %> alert-dismissible fade show" role="alert">
        <strong><%= message %></strong>
        <input id="urlToRedirect" type="hidden" value="/products/add" />
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" onclick="closeAlert()"></button>
      </div>
    <% } %>
    <form action="/products/save" method="POST" enctype="multipart/form-data">
      <div class="mb-3 row">
        <label for="name" class="col-sm-2 col-form-label">Name</label>
        <div class="col-sm-10">
          <input type="text" class="form-control" id="name" name="name" required>
        </div>
      </div>

      <div class="mb-3 row">
        <label for="description" class="col-sm-2 col-form-label">Description</label>
        <div class="col-sm-10">
          <textarea class="form-control" id="description" name="description" rows="4"></textarea>
        </div>
      </div>

      <% if (typeof categories !== "undefined" && categories.length > 0) { %>
            <div class="mb-3 row">
                <label for="category" class="col-sm-3 col-form-label">Category:</label>
                <div class="col-sm-9">
                <select name="category" id="category">
                    <option value="">None</option>
                    <% categories.forEach(category => { %>
                    <option value="<%= category._id %>"><%= category.name %></option>
                    <% }) %>
                </select><br>
                </div>
            </div>
        <% } %>

      <div class="mb-3 row">
        <label for="brand" class="col-sm-2 col-form-label">Brand</label>
        <div class="col-sm-10">
          <input type="text" class="form-control" id="brand" name="brand">
        </div>
      </div>

      <div class="mb-3 row">
        <label for="images" class="col-sm-2 col-form-label">Images (URLs)</label>
        <div class="col-sm-10">
          <input type="file" class="form-control" id="images" name="images" placeholder="https://example.com/image.jpg" multiple>
        </div>
      </div>

      <% if (typeof sizes !== "undefined" && sizes.length > 0) { %>
        <div class="mb-3 row">
          <table class="table">
            <tbody>
               <thead>
                <tr>
                  <th scope="col">Size</th>
                  <th scope="col">Price</th>
                  <th scope="col">Discount (%)</th>
                  <th scope="col">Stock</th>
                </tr>
              </thead>
              <% sizes.forEach(size => { %>
                <tr>
                  <th scope="row"><%= size.name %></th>
                  <input type="hidden" name="size[]" value="<%=size._id%>" />
                  <td>
                    <div class="mb-3 row">
                      <div class="col-sm-10">
                        <input type="number" class="form-control" name="price[]" step="0.01" min="0">
                      </div>
                    </div>
                  </td>
                  <td>
                    <div class="mb-3 row">
                      <div class="col-sm-10">
                        <input type="number" class="form-control"name="discount[]" step="0.01" min="0">
                      </div>
                    </div>
                  </td>
                  <td>
                    <div class="mb-3 row">
                      <div class="col-sm-10">
                        <input type="number" class="form-control"name="stock[]" step="0.01" min="0">
                      </div>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
      

      <div class="mb-3 row">
        <div class="col-sm-10 offset-sm-2">
          <button type="submit" class="btn btn-primary">Add Product</button>
        </div>
      </div>

    </form>

  </div>
</div>
  