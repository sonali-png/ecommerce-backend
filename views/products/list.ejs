<div class="col-sm-10">
  <div class="col-sm-10">
    <table class="table table-hover">
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">Name</th>
          <th>description</th>
          <th>category</th>
          <th>brand</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% productList.forEach((prod) => { %>
          <tr>
            <td><%= prod._id %></td>
            <td><%= prod.name %></td>
            <td><%= prod.description %></td>
            <td><%= prod.category %></td>
            <td><%= prod.brand %></td>
            <td><i class="bi bi-pencil-square"></i> | <i class="bi bi-trash3"></i></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <nav aria-label="Page navigation example">
      <ul class="pagination justify-content-center">
        <% if (page > 1) { %>
          <li class="page-item">
            <a class="page-link" href="<%= page === 2 ? '/products' : '?page=' + (page - 1) %>">Previous</a>
          </li>
        <% } %>

        <% for (let i = 1; i <= pages; i++) { %>
          <li class="page-item <%= page === i ? 'active' : '' %>">
            <a class="page-link" href="<%= i === 1 ? '/products' : '?page=' + i %>"><%= i %></a>
          </li>
        <% } %>

        <% if (page < pages) { %>
          <li class="page-item">
            <a class="page-link" href="?page=<%= page + 1 %>">Next</a>
          </li>
        <% } %>

      </ul>
    </nav>
  </div>
</div>
  